{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "code-reading",
  "version": "0.1.0",
  "identifier": "com.ricroad.code-reading",
  "build": {
    "beforeDevCommand": "/Users/yufeng.he/.local/node/bin/pnpm dev",
    "beforeBuildCommand": "/Users/yufeng.he/.local/node/bin/pnpm build",
    "devUrl": "http://127.0.0.1:5174",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "code-reading",
        "width": 1440,
        "height": 960,
        "minWidth": 1180,
        "minHeight": 760
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/64x64.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
